# Environment Variables for UAD 3.6 QC Engine
QC_AI_BACKEND=stub
GEMINI_API_KEY=
# Gemini model id. Defaults to gemini-2.0-flash if unset. (The old default
# "gemini-3.5-flash" is not a real model and 404s every AI call.)
QC_AI_MODEL=gemini-2.0-flash
QC_DATA_CLASS=sample
QC_XSD_PATH=
QC_RULES_PATH=
QC_MANIFEST_PATH=
QC_DATA_DIR=

# GCS bucket name for the direct-to-storage large-upload path (POST
# /api/uploads/init). Cloud Run rejects any request over ~32MB before it
# reaches this app, so uploads near that size go straight to this bucket via
# a signed URL instead. Set by infra/deploy-gcp.ps1 to the same bucket already
# used for retained report files. Leave blank in local dev -- uploads fall
# back to the direct multipart path (no 32MB ceiling to work around locally).
# Requires the runtime service account to hold roles/iam.serviceAccountTokenCreator
# on itself (needed to sign V4 URLs via ADC) and roles/storage.objectAdmin on
# the bucket -- both wired by deploy-gcp.ps1.
QC_UPLOAD_BUCKET=

# Auth: no identity header (X-QC-User-Email, X-QC-User-Bubble-Id, X-QC-Role) is
# trusted at all -- not even to look a user up in users.json -- unless the request
# also carries this exact value as the X-QC-Proxy-Secret header. Only the trusted
# proxy (e.g. Bubble) should know it. Leave blank in production and every caller
# is treated as an anonymous guest at the lowest privilege (appraiser, no elevated
# routes) -- functional, but nobody gets their real identity or admin/reviewer
# access until this is set. Required for the deployed environment.
QC_PROXY_SECRET=

# Python interpreter for the supplemental rules engine (default: python3).
# On Windows dev the binary is usually "python".
QC_PYTHON_BIN=python3
# Set to 1 to disable the Python supplemental rules engine entirely.
QC_DISABLE_SUPPLEMENTAL=
