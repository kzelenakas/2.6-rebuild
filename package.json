{
  "name": "uad36-qc",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "npm run build:frontend && npm run build:server",
    "build:frontend": "npm --prefix frontend run build",
    "build:server": "esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "latest",
    "@tailwindcss/vite": "^4.3.2",
    "@xmldom/xmldom": "latest",
    "adm-zip": "latest",
    "express": "^4.21.2",
    "multer": "latest",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2"
  },
  "overrides": {
    "node-domexception": "file:./node-domexception-noop"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
